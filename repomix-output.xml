                  </div>
                </div>

                <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {/* Installation Date */}
                  <div className="flex flex-col gap-1">
                    <label htmlFor="edit-eq-install" className="font-label-caps text-label-caps text-on-surface-variant">
